# 可选：POST /api/policy-feed/sync 等写操作校验
MONITOR_API_TOKEN=

# Knot Client 工具 Header: X-Bot-Token（建议设置；留空则不校验）
KNOT_BOT_TOKEN=

# 上线后填写，/api/meta 会返回给未来操作台
PUBLIC_BASE_URL=

# 服务端口（start.sh / deploy 使用）
PORT=18888

# 企微早报/周报（GitHub Actions Secrets 或本地 --notify）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
POLICY_DIGEST_WECOM_USERS=

# 邮件推送（可选）
POLICY_DIGEST_EMAIL_TO=
POLICY_SMTP_HOST=
POLICY_SMTP_PORT=587
POLICY_SMTP_USER=
POLICY_SMTP_PASSWORD=
POLICY_SMTP_FROM=
POLICY_SMTP_TLS=true
